{
  "name": "sgt",
  "version": "1.0.0",
  "description": "",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint src/renderer --fix",
    "format": "prettier --write src/renderer/**/*.{js,jsx,css}",
    "dist": "npm run build && electron-builder --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never"
  },
  "build": {
    "appId": "com.tuempresa.sgt",
    "productName": "SGT",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/php/linux",
        "to": "php/linux",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/php/win",
        "to": "php/win",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/php/mac",
        "to": "php/mac",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/mysql/linux",
        "to": "mysql/linux",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/mysql/win",
        "to": "mysql/win",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/mysql/mac",
        "to": "mysql/mac",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "backend",
        "to": "backend"
      }
    ],
    "linux": {
      "target": [
        "dir",
        "tar.gz"
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-linux.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false
    },
    "mac": {
      "target": "dmg",
      "artifactName": "${productName}-${version}-mac.${ext}",
      "category": "public.app-category.productivity",
      "darkModeSupport": true
    },
    "dmg": {
      "title": "${productName} ${version}"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EduardGarrido/SGT.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/EduardGarrido/SGT/issues"
  },
  "homepage": "https://github.com/EduardGarrido/SGT#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "postcss": "^8.5.10",
    "prettier": "^3.8.2",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "clsx": "^2.1.1",
    "daisyui": "^5.5.19",
    "dompurify": "^3.4.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0"
  }
}
